# ============================================================
# 이 파일은 커밋됩니다. 실제 키는 .env 에 넣고 절대 커밋 금지.
# 복사: cp .env.example .env
# ============================================================

# ---- Database (Neon PostgreSQL) ----
# Neon 대시보드 → Connection string → "psycopg" 형식 권장
# 예: postgresql+psycopg://USER:PASSWORD@HOST/DB?sslmode=require
DATABASE_URL=
MARKET_DATABASE_URL=  # market 전용 DB(:5434) — 미설정 시 DATABASE_URL 폴백(메인 DB)

# ---- Database (로컬 docker-compose pgvector) ----
# docker-compose.yaml의 기본값(redocean)은 공개 저장소에 노출된 값이므로 실제 비밀번호를 여기서 덮어쓴다.
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=

# ---- 공공데이터 API 키 ----
# 서울 열린데이터광장 (data.seoul.go.kr) - 메인 데이터 출처
SEOUL_OPENDATA_API_KEY=

# 공공데이터포털 (data.go.kr) - 보조 데이터 출처
DATA_GO_KR_API_KEY=

# ---- Auth (JWT RS256) ---- 생성: minseok/scripts/generate_jwt_keys.sh
# 공개키(검증) — 전 컨테이너 공용. 개인키(발급)는 .env.auth에만 둔다(auth 컨테이너 전용).
JWT_PUBLIC_KEY_B64=

# ---- API 문서 보호 (/docs·/redoc·/openapi.json — HTTP Basic) ----
# 미설정 시 문서 접근 전면 차단. 개발자 브라우저 로그인창 계정.
DOCS_USER=
DOCS_PASSWORD=
# 리프레시 토큰 저장소 — 미설정 시 redis://localhost:6379/0 (컨테이너는 compose가 redis://redis:6379/0 주입)
# REDIS_URL=

# ---- Auth (소셜 로그인 OAuth — 백엔드가 인가 코드 교환에 사용) ----
# 구글: console.cloud.google.com → API 및 서비스 → 사용자 인증 정보 → OAuth 클라이언트 ID(웹)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# 카카오: developers.kakao.com → 앱 키의 "REST API 키" (시크릿은 보안 탭에서 켠 경우만)
KAKAO_CLIENT_ID=
KAKAO_CLIENT_SECRET=
# 네이버: developers.naver.com → 애플리케이션 등록(네이버 로그인)
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=

# ---- LLM (Phase 4에서 선택, 자리만 준비) ----
# GEMINI_API_KEY=
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=

# ---- DART (금융감독원 전자공시) API Key ----
DART_API_KEY=

# ---- Frontend (www/) ----
# Next.js는 www/ 안의 env 파일만 읽는다 — 로컬은 www/.env.local에, 배포는 버셀 환경변수에 설정.
# 카카오맵 JS 키 (developers.kakao.com — 플랫폼>Web 사이트 도메인에 서비스 도메인 등록 필수)
NEXT_PUBLIC_KAKAO_MAP_KEY=
# 백엔드 주소 — rewrites(/api/backend/*)·/api/chat 프록시 대상. 로컬 기본 http://127.0.0.1:8000, 배포는 공개 백엔드 주소
NEXT_PUBLIC_API_URL=
# 소셜 로그인 클라이언트 ID (인가 URL 조립용 — 시크릿은 백엔드에만).
# 각 사 콘솔의 리다이렉트 URI에 <origin>/oauth/google|kakao|naver 를 등록해야 한다.
NEXT_PUBLIC_GOOGLE_CLIENT_ID=
NEXT_PUBLIC_KAKAO_CLIENT_ID=
NEXT_PUBLIC_NAVER_CLIENT_ID=