# ============================================================
# 이 파일은 커밋됩니다. 실제 키는 .env 에 넣고 절대 커밋 금지.
# 복사: cp .env.example .env
# ============================================================

# ---- Database (Neon PostgreSQL) ----
# Neon 대시보드 → Connection string → "psycopg" 형식 권장
# 예: postgresql+psycopg://USER:PASSWORD@HOST/DB?sslmode=require
DATABASE_URL=

# ---- 공공데이터 API 키 ----
# 서울 열린데이터광장 (data.seoul.go.kr) - 메인 데이터 출처
SEOUL_OPENDATA_API_KEY=

# 공공데이터포털 (data.go.kr) - 보조 데이터 출처
DATA_GO_KR_API_KEY=

# ---- Auth (JWT) ----
JWT_SECRET=

# ---- LLM (Phase 4에서 선택, 자리만 준비) ----
# GEMINI_API_KEY=
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
